#include <iostream>   // Allows us to use cout, endl, etc.
using namespace std;  // So we can write cout instead of std::cout

// This function looks for all pairs in the array that add up to 'target'
void findPairsThatSumToTarget(int arr[], int n, int target) {
    bool found = false;  // Will become true if we find at least one matching pair

    // Outer loop: choose the first element of the pair
    for (int i = 0; i < n; ++i) {
        // Inner loop: choose the second element of the pair
        // Start at i + 1 so we don't repeat pairs or use the same element twice
        for (int j = i + 1; j < n; ++j) {
            // Check if the sum of the two chosen elements equals the target
            if (arr[i] + arr[j] == target) {
                cout << "Pair found: " << arr[i] << " + " << arr[j]
                     << " = " << target << endl;
                found = true;  // Remember that we found at least one valid pair
            }
        }
    }

    // If no pairs were found, tell the user
    if (!found) {
        cout << "No pair sums to " << target << endl;
    }
}

int main() {
    // Our array of numbers
    int arr[] = {1, 3, 10, 11, 14};

    // Calculate how many elements are in the array:
    // total bytes of arr / bytes of one element
    int n = sizeof(arr) / sizeof(arr[0]);

    // The target sum we are looking for
    int target = 13;

    // Call our function to do the work
    findPairsThatSumToTarget(arr, n, target);

    // Return 0 to indicate the program finished successfully
    return 0;
}